[Unit]
Description=Vocipher Voice Chat Server
After=network.target

[Service]
Type=simple
User=vocipher
Group=vocipher
ExecStart=/usr/bin/vocipher -config /etc/vocipher/config.yaml
WorkingDirectory=/usr/share/vocipher
Restart=on-failure
RestartSec=5
LimitNOFILE=65536

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/vocipher

[Install]
WantedBy=multi-user.target
